---
// BlogPostLayout.astro
// Editorial reading chrome: fixed scroll-progress bar, meta line, serif h1,
// prose container (max-width 720px), Shiki code styling, back link.

import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  tags?: string[];
  readTime: number;
}

const { title, description, pubDate, tags = [], readTime } = Astro.props;

const primaryTag = tags[0] ?? null;

const formattedDate = pubDate.toLocaleDateString('en-IE', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});

const isoDate = pubDate.toISOString().slice(0, 10);
---

<BaseLayout title={`${title} · Guilherme de Mello`} description={description}>
  <!-- Fixed scroll-progress bar -->
  <div id="progress-bar" aria-hidden="true"></div>

  <article class="blog-post section">
    <div class="container prose-wrap">
      <!-- Back link -->
      <a href="/blog" class="back-link mono">← Back to writing</a>

      <!-- Post header -->
      <header class="post-header">
        <p class="meta mono">
          {primaryTag && <span class="meta-tag">{primaryTag}</span>}
          {primaryTag && <span class="meta-sep">·</span>}
          <span>{readTime} min read</span>
          <span class="meta-sep">·</span>
          <time datetime={isoDate}>{formattedDate}</time>
        </p>
        <h1 class="post-title serif">{title}</h1>
        {description && <p class="post-standfirst muted">{description}</p>}
      </header>

      <!-- Prose body -->
      <div class="prose">
        <slot />
      </div>

      <!-- Footer back link -->
      <a href="/blog" class="back-link back-link--footer mono">← Back to writing</a>
    </div>
  </article>
</BaseLayout>

<script>
  import '../scripts/progress.ts';
</script>

<style>
  /* -----------------------------------------------------------------------
     Scroll-progress bar
     ----------------------------------------------------------------------- */
  #progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: 3px;
    background: var(--accent);
    z-index: 1000;
    pointer-events: none;
    /* No transition — keep updates instant to avoid lag */
  }

  /* -----------------------------------------------------------------------
     Page layout
     ----------------------------------------------------------------------- */
  .blog-post {
    padding-top: var(--sp-7);
    padding-bottom: var(--sp-8);
  }

  .prose-wrap {
    max-width: 720px;
  }

  /* -----------------------------------------------------------------------
     Back link
     ----------------------------------------------------------------------- */
  .back-link {
    display: inline-flex;
    align-items: center;
    font-size: var(--fs-mono-label);
    letter-spacing: 0.08em;
    color: var(--text-dim);
    text-decoration: none;
    text-transform: uppercase;
    transition: color var(--dur-hover) var(--ease-out);
    margin-bottom: var(--sp-6);
  }

  .back-link:hover {
    color: var(--accent);
  }

  .back-link--footer {
    margin-top: var(--sp-8);
    margin-bottom: 0;
  }

  /* -----------------------------------------------------------------------
     Post header
     ----------------------------------------------------------------------- */
  .post-header {
    margin-bottom: var(--sp-7);
  }

  .meta {
    font-size: var(--fs-mono-label);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35em;
    margin-bottom: var(--sp-4);
  }

  .meta-tag {
    color: var(--accent);
  }

  .meta-sep {
    opacity: 0.5;
  }

  .post-title {
    font-size: clamp(1.9rem, 5vw, 3rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 400; /* Instrument Serif looks better at regular weight */
    color: var(--text);
    margin-bottom: var(--sp-4);
  }

  .post-standfirst {
    font-size: 1.125rem;
    line-height: 1.65;
    color: var(--text-muted);
    max-width: 60ch;
  }

  /* -----------------------------------------------------------------------
     Prose container — reading typography
     ----------------------------------------------------------------------- */
  .prose {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--text);
  }

  /* Headings */
  .prose :global(h2) {
    font-size: clamp(1.35rem, 3vw, 1.75rem);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.015em;
    color: var(--text);
    margin-top: var(--sp-7);
    margin-bottom: var(--sp-4);
  }

  .prose :global(h3) {
    font-size: 1.2rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--text);
    margin-top: var(--sp-6);
    margin-bottom: var(--sp-3);
  }

  .prose :global(h4),
  .prose :global(h5),
  .prose :global(h6) {
    font-size: var(--fs-body);
    font-weight: 600;
    color: var(--text);
    margin-top: var(--sp-5);
    margin-bottom: var(--sp-2);
  }

  /* Paragraphs */
  .prose :global(p) {
    margin-bottom: var(--sp-5);
    color: var(--text);
  }

  /* Lists */
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: var(--sp-5);
  }

  .prose :global(ul) {
    list-style: disc;
  }

  .prose :global(ol) {
    list-style: decimal;
  }

  .prose :global(li) {
    margin-bottom: var(--sp-2);
    line-height: 1.7;
  }

  .prose :global(li > ul),
  .prose :global(li > ol) {
    margin-top: var(--sp-2);
    margin-bottom: 0;
  }

  /* Links */
  .prose :global(a) {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur-hover) var(--ease-out);
  }

  .prose :global(a:hover) {
    border-bottom-color: var(--accent);
  }

  /* Blockquote */
  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: var(--sp-4) var(--sp-5);
    margin: var(--sp-6) 0;
    background: var(--surface);
    border-radius: 0 var(--r-card) var(--r-card) 0;
    color: var(--text-muted);
    font-style: italic;
  }

  .prose :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  /* Horizontal rule */
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: var(--sp-7) 0;
  }

  /* Images */
  .prose :global(img) {
    border-radius: var(--r-card);
    max-width: 100%;
    margin: var(--sp-6) auto;
  }

  /* Inline code (not inside a pre) */
  .prose :global(:not(pre) > code) {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.875em;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.1em 0.35em;
    color: var(--syntax-string);
  }

  /* Shiki code blocks */
  .prose :global(pre.astro-code),
  .prose :global(.shiki) {
    margin: var(--sp-6) 0;
    /* padding, radius, overflow handled by syntax.css */
  }

  /* Strong / em */
  .prose :global(strong) {
    font-weight: 600;
    color: var(--text);
  }

  .prose :global(em) {
    font-style: italic;
  }

  /* -----------------------------------------------------------------------
     Responsive
     ----------------------------------------------------------------------- */
  @media (max-width: 760px) {
    .blog-post {
      padding-top: var(--sp-6);
    }

    .post-title {
      font-size: clamp(1.6rem, 6vw, 2.25rem);
    }

    .prose {
      font-size: 1rem;
    }
  }

  /* -----------------------------------------------------------------------
     Reduced motion
     ----------------------------------------------------------------------- */
  @media (prefers-reduced-motion: reduce) {
    .back-link,
    .prose :global(a) {
      transition: none;
    }
  }
</style>
