---
// Nav.astro
// Sticky top navigation: GM. monogram (left), nav links (center/right), ThemeToggle (right).
// nav.ts adds .scrolled class at scrollY > 60 for backdrop-blur effect.
import ThemeToggle from './ThemeToggle.astro';
---

<header id="site-nav" class="nav" role="banner">
  <div class="nav-inner container">
    <!-- Left: GM. monogram wordmark -->
    <a href="/" class="nav-logo" aria-label="Guilherme de Mello — Home">
      GM<span class="accent" aria-hidden="true">.</span>
    </a>

    <!-- Center/Right: Desktop nav links -->
    <nav class="nav-links" aria-label="Main navigation">
      <a href="/" class="nav-link">Home</a>
      <a href="/about" class="nav-link">About</a>
      <a href="/blog" class="nav-link">Blog</a>
      <a href="/contact" class="nav-link">Contact</a>
    </nav>

    <!-- Right: Theme toggle + hamburger -->
    <div class="nav-actions">
      <ThemeToggle />

      <!-- Mobile hamburger -->
      <button
        id="nav-hamburger"
        class="hamburger"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open navigation menu"
      >
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="mobile-menu" aria-hidden="true" role="navigation" aria-label="Mobile navigation">
    <nav class="mobile-links">
      <a href="/" class="mobile-link">Home</a>
      <a href="/about" class="mobile-link">About</a>
      <a href="/blog" class="mobile-link">Blog</a>
      <a href="/contact" class="mobile-link">Contact</a>
    </nav>
  </div>
</header>

<script>
  import { initNav, initMobileMenu } from '../scripts/nav.ts';

  const nav = document.getElementById('site-nav') as HTMLElement | null;
  const hamburger = document.getElementById('nav-hamburger') as HTMLButtonElement | null;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement | null;

  if (nav) initNav(nav);
  if (hamburger && mobileMenu) initMobileMenu(hamburger, mobileMenu);
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    transition:
      background var(--dur-hover) var(--ease-out),
      box-shadow var(--dur-hover) var(--ease-out),
      backdrop-filter var(--dur-hover) var(--ease-out);
  }

  /* Scrolled state: add frosted-glass effect */
  .nav.scrolled {
    background: color-mix(in srgb, var(--bg) 80%, transparent);
    backdrop-filter: blur(12px) saturate(1.4);
    -webkit-backdrop-filter: blur(12px) saturate(1.4);
    box-shadow: 0 1px 0 var(--border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
    gap: var(--sp-5);
  }

  /* Logo / monogram */
  .nav-logo {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 1.125rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text);
    text-decoration: none;
    flex-shrink: 0;
    transition: opacity var(--dur-hover) var(--ease-out);
  }

  .nav-logo:hover {
    opacity: 0.7;
  }

  /* Desktop links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--sp-5);
  }

  .nav-link {
    font-size: var(--fs-small);
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    letter-spacing: 0.01em;
    position: relative;
    transition: color var(--dur-hover) var(--ease-out);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--accent);
    transition: width var(--dur-hover) var(--ease-out);
  }

  .nav-link:hover {
    color: var(--text);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  /* Actions: toggle + hamburger */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    flex-shrink: 0;
  }

  /* Hamburger — mobile only */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.25rem;
    height: 2.25rem;
    background: transparent;
    border: 1.5px solid var(--border);
    border-radius: var(--r-card);
    cursor: pointer;
    padding: 0 0.5rem;
    transition:
      background var(--dur-hover) var(--ease-out),
      border-color var(--dur-hover) var(--ease-out);
  }

  .hamburger:hover {
    background: var(--surface);
    border-color: var(--accent);
  }

  .hamburger-line {
    display: block;
    width: 100%;
    height: 1.5px;
    background: var(--text-muted);
    border-radius: 1px;
    transition: transform var(--dur-hover) var(--ease-out), opacity var(--dur-hover) var(--ease-out);
  }

  /* Mobile menu */
  .mobile-menu {
    display: none;
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.3s var(--ease-out);
    border-top: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 95%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .mobile-menu.open {
    max-height: 20rem;
  }

  .mobile-links {
    display: flex;
    flex-direction: column;
    padding: var(--sp-4) 0;
  }

  .mobile-link {
    display: block;
    padding: var(--sp-3) var(--sp-6);
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--dur-hover) var(--ease-out), background var(--dur-hover) var(--ease-out);
  }

  .mobile-link:hover {
    color: var(--text);
    background: var(--surface);
  }

  /* Responsive breakpoints */
  @media (max-width: 680px) {
    .nav-links {
      display: none;
    }

    .hamburger {
      display: flex;
    }

    .mobile-menu {
      display: block;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .nav,
    .nav-link,
    .nav-link::after,
    .nav-logo,
    .hamburger,
    .hamburger-line,
    .mobile-menu,
    .mobile-link {
      transition: none;
    }

    .mobile-menu.open {
      max-height: none;
    }
  }
</style>
