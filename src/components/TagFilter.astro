---
// TagFilter.astro
// Renders "All" + one pill per unique tag. Client-side TS filters post rows
// by matching data-tags attribute — no page reload. Accessible: aria-pressed.
interface Props {
  tags: string[];
}
const { tags } = Astro.props;
---

<div class="tag-filter" role="group" aria-label="Filter posts by tag">
  <button
    class="tag-pill tag-pill--active"
    data-tag="all"
    aria-pressed="true"
    type="button"
  >
    All
  </button>
  {tags.map((tag) => (
    <button
      class="tag-pill"
      data-tag={tag}
      aria-pressed="false"
      type="button"
    >
      {tag}
    </button>
  ))}
</div>

<script>
  const filter = document.querySelector<HTMLDivElement>('.tag-filter');
  if (filter) {
    const pills = filter.querySelectorAll<HTMLButtonElement>('.tag-pill');
    const rows = document.querySelectorAll<HTMLElement>('[data-tags]');
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function setActive(pill: HTMLButtonElement) {
      pills.forEach((p) => {
        p.classList.remove('tag-pill--active');
        p.setAttribute('aria-pressed', 'false');
      });
      pill.classList.add('tag-pill--active');
      pill.setAttribute('aria-pressed', 'true');
    }

    function filterRows(activeTag: string) {
      rows.forEach((row) => {
        const rowTags = (row.dataset.tags ?? '').split(',').map((t) => t.trim());
        const show = activeTag === 'all' || rowTags.includes(activeTag);

        if (prefersReducedMotion) {
          row.style.display = show ? '' : 'none';
        } else {
          if (show) {
            row.style.display = '';
            // Trigger reflow so opacity transition fires
            void row.offsetHeight;
            row.style.opacity = '1';
          } else {
            row.style.opacity = '0';
            const onEnd = () => {
              if (row.style.opacity === '0') row.style.display = 'none';
              row.removeEventListener('transitionend', onEnd);
            };
            row.addEventListener('transitionend', onEnd);
          }
        }
      });
    }

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        const tag = pill.dataset.tag ?? 'all';
        setActive(pill);
        filterRows(tag);
      });
    });
  }
</script>

<style>
  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .tag-pill {
    display: inline-flex;
    align-items: center;
    padding: var(--sp-1) var(--sp-3);
    border-radius: var(--r-pill);
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-muted);
    font-family: var(--font-mono, monospace);
    font-size: var(--fs-mono-label, 0.75rem);
    letter-spacing: 0.06em;
    cursor: pointer;
    transition:
      background var(--dur-hover) var(--ease-out),
      color var(--dur-hover) var(--ease-out),
      border-color var(--dur-hover) var(--ease-out);
  }

  .tag-pill:hover {
    border-color: var(--accent);
    color: var(--text);
  }

  .tag-pill--active {
    background: var(--accent-soft);
    border-color: var(--accent);
    color: var(--accent);
  }

  .tag-pill:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .tag-pill {
      transition: none;
    }
  }
</style>
