---
// WritingTeaser.astro
// Shows up to 3 latest blog posts. Links to /blog.
// TODO Task 8: replace stub posts with getCollection('blog') sorted by pubDate desc

interface Post {
  title: string;
  excerpt: string;
  date: string;
  slug: string;
}

// TODO Task 8: replace this stub array with getCollection('blog') sorted by pubDate desc
const posts: Post[] = [
  {
    title: 'Building AI-Powered Features with Foundation Models in SwiftUI',
    excerpt: 'How to integrate on-device Foundation Models into a production SwiftUI app without sacrificing architecture.',
    date: '2026-06-15',
    slug: 'foundation-models-swiftui',
  },
  {
    title: 'Clean Architecture in Swift: A Practical 2026 Guide',
    excerpt: 'Protocols, dependency injection, and testable modules — the structure I reach for on every new project.',
    date: '2026-05-28',
    slug: 'clean-architecture-swift-2026',
  },
  {
    title: 'What WWDC25 Means for Senior iOS Engineers',
    excerpt: 'My notes from Apple Park: the APIs I am most excited about and the patterns I am rethinking.',
    date: '2026-05-12',
    slug: 'wwdc25-senior-ios-engineer',
  },
];

function formatDate(iso: string): string {
  const d = new Date(iso);
  return d.toLocaleDateString('en-IE', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<div class="writing-teaser">
  <ul class="writing-list" role="list">
    {posts.map((post) => (
      <li class="writing-row">
        <a
          href={`/blog/${post.slug}`}
          class="writing-link"
          aria-label={`Read: ${post.title}`}
        >
          <div class="writing-main">
            <strong class="writing-title">{post.title}</strong>
            <p class="writing-excerpt muted">{post.excerpt}</p>
          </div>
          <time
            class="writing-date mono"
            datetime={post.date}
          >
            {formatDate(post.date)}
          </time>
        </a>
      </li>
    ))}
  </ul>

  <div class="writing-footer">
    <a href="/blog" class="writing-all mono" aria-label="View all writing on the blog">
      All writing →
    </a>
  </div>
</div>

<style>
  .writing-teaser {
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
  }

  .writing-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--border);
  }

  .writing-row {
    border-bottom: 1px solid var(--border);
  }

  .writing-link {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--sp-5);
    padding: var(--sp-5) 0;
    text-decoration: none;
    color: inherit;
    transition: opacity var(--dur-hover) var(--ease-out);
  }

  .writing-link:hover {
    opacity: 0.7;
  }

  .writing-link:hover .writing-title {
    color: var(--accent);
  }

  .writing-main {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    flex: 1;
    min-width: 0;
  }

  .writing-title {
    font-size: var(--fs-body);
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
    transition: color var(--dur-hover) var(--ease-out);
  }

  .writing-excerpt {
    font-size: var(--fs-small);
    line-height: 1.55;
    color: var(--text-muted);
  }

  .writing-date {
    font-size: var(--fs-mono-label);
    color: var(--text-dim);
    letter-spacing: 0.06em;
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 0.15em;
  }

  .writing-footer {
    display: flex;
    justify-content: flex-end;
  }

  .writing-all {
    font-size: var(--fs-small);
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-decoration: none;
    transition:
      color var(--dur-hover) var(--ease-out),
      letter-spacing var(--dur-hover) var(--ease-out);
  }

  .writing-all:hover {
    color: var(--accent);
    letter-spacing: 0.1em;
  }

  @media (prefers-reduced-motion: reduce) {
    .writing-link,
    .writing-title,
    .writing-all {
      transition: none;
    }
    .writing-all:hover {
      letter-spacing: 0.06em;
    }
  }

  @media (max-width: 760px) {
    .writing-link {
      flex-direction: column;
      gap: var(--sp-3);
    }

    .writing-date {
      padding-top: 0;
    }
  }
</style>
