---
// WorkCard.astro
// Project card with optional image. If no image, renders a placeholder box.
// Whole card links if href provided.

interface Props {
  title: string;
  blurb: string;
  meta: string;
  href?: string;
  image?: string;
  cta?: string;
  viewAll?: boolean;
}

const {
  title,
  blurb,
  meta,
  href,
  image,
  cta = 'View project →',
  viewAll = false,
} = Astro.props;

const Tag = href ? 'a' : 'div';
const linkProps = href
  ? {
      href,
      ...(href !== '#' && !href.startsWith('/')
        ? { target: '_blank', rel: 'noopener noreferrer' }
        : {}),
      'aria-label': `${title} — ${blurb}`,
    }
  : {};
---

<Tag class={`work-card${viewAll ? ' work-card--view-all' : ''}`} {...linkProps}>
  {viewAll ? (
    <div class="work-card-all-inner">
      <span class="work-card-all-arrow" aria-hidden="true">→</span>
      <span class="serif work-card-all-label">View all work</span>
    </div>
  ) : (
    <>
      <div class="work-card-image" aria-hidden="true">
        {image ? (
          <img src={image} alt={title} loading="lazy" decoding="async" />
        ) : (
          <div class="work-card-placeholder">
            <span class="mono work-card-placeholder-label">screenshot</span>
          </div>
        )}
      </div>
      <div class="work-card-body">
        <h3 class="work-card-title serif">{title}</h3>
        <p class="work-card-blurb muted">{blurb}</p>
        <p class="work-card-meta mono">{meta}</p>
        {href && (
          <span class="work-card-cta mono" aria-hidden="true">{cta}</span>
        )}
      </div>
    </>
  )}
</Tag>

<style>
  .work-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-card);
    overflow: hidden;
    transition:
      transform var(--dur-hover) var(--ease-out),
      box-shadow var(--dur-hover) var(--ease-out),
      border-color var(--dur-hover) var(--ease-out);
    text-decoration: none;
    color: inherit;
  }

  .work-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
    border-color: var(--text-dim);
  }

  @media (prefers-reduced-motion: reduce) {
    .work-card {
      transition: none;
    }
    .work-card:hover {
      transform: none;
    }
  }

  /* Image area */
  .work-card-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--surface-2);
  }

  .work-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out);
  }

  .work-card:hover .work-card-image img {
    transform: scale(1.04);
  }

  @media (prefers-reduced-motion: reduce) {
    .work-card:hover .work-card-image img {
      transform: none;
    }
  }

  /* Placeholder (no image) */
  .work-card-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(
      135deg,
      var(--surface-2) 0%,
      var(--surface) 60%,
      var(--surface-2) 100%
    );
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .work-card-placeholder-label {
    font-size: var(--fs-mono-label);
    color: var(--text-dim);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  /* Card body */
  .work-card-body {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-5);
    flex: 1;
  }

  .work-card-title {
    font-size: var(--fs-h3);
    font-weight: 400;
    line-height: 1.2;
    color: var(--text);
  }

  .work-card-blurb {
    font-size: var(--fs-body);
    line-height: 1.55;
    color: var(--text-muted);
  }

  .work-card-meta {
    font-size: var(--fs-mono-label);
    color: var(--text-dim);
    letter-spacing: 0.06em;
    line-height: 1.5;
    margin-top: auto;
  }

  .work-card-cta {
    font-size: var(--fs-mono-label);
    color: var(--accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    display: inline-block;
    transition: letter-spacing var(--dur-hover) var(--ease-out);
  }

  .work-card:hover .work-card-cta {
    letter-spacing: 0.1em;
  }

  @media (prefers-reduced-motion: reduce) {
    .work-card:hover .work-card-cta {
      letter-spacing: 0.06em;
    }
  }

  /* "View all" variant */
  .work-card--view-all {
    min-height: 220px;
    align-items: center;
    justify-content: center;
    border-style: dashed;
    cursor: pointer;
  }

  .work-card--view-all:hover {
    border-color: var(--accent);
    border-style: solid;
  }

  .work-card-all-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-5);
    text-align: center;
  }

  .work-card-all-arrow {
    font-size: 2rem;
    color: var(--accent);
    transition: transform var(--dur-hover) var(--ease-out);
    line-height: 1;
  }

  .work-card--view-all:hover .work-card-all-arrow {
    transform: translateX(4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .work-card--view-all:hover .work-card-all-arrow {
      transform: none;
    }
  }

  .work-card-all-label {
    font-size: var(--fs-h3);
    font-weight: 400;
    color: var(--text);
  }
</style>
