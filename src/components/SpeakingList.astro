---
interface SpeakingItem {
  when: string;
  title: string;
  detail?: string;
  upcoming?: boolean;
}

interface Props {
  items: SpeakingItem[];
}

const { items } = Astro.props;
---

<ul class="speaking-list" aria-label="Speaking and community engagements">
  {items.map((item) => (
    <li class="speaking-item">
      <span class="speaking-when mono">{item.when}</span>
      <div class="speaking-body">
        <span class="speaking-title">
          {item.title}
          {item.upcoming && (
            <span class="speaking-badge" aria-label="Upcoming event">Upcoming</span>
          )}
        </span>
        {item.detail && (
          <span class="speaking-detail muted">{item.detail}</span>
        )}
      </div>
    </li>
  ))}
</ul>

<style>
  .speaking-list {
    list-style: none;
    margin: var(--sp-6) 0 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .speaking-item {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: var(--sp-5);
    padding: var(--sp-5) 0;
    border-bottom: 1px solid var(--border);
    align-items: start;
    transition: background var(--dur-hover) var(--ease-out);
  }

  .speaking-item:first-child {
    border-top: 1px solid var(--border);
  }

  .speaking-when {
    font-size: var(--fs-mono-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
    padding-top: 2px;
  }

  .speaking-body {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .speaking-title {
    font-size: var(--fs-body);
    font-weight: 600;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }

  .speaking-badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 10px;
    border-radius: var(--r-pill);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: var(--accent);
    color: var(--accent-fg);
    flex-shrink: 0;
  }

  .speaking-detail {
    font-size: var(--fs-small);
    color: var(--text-muted);
  }

  /* Responsive */
  @media (max-width: 760px) {
    .speaking-item {
      grid-template-columns: 1fr;
      gap: var(--sp-2);
    }
  }
</style>
