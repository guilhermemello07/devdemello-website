---
// index.astro
// Home page — the full scrolling story.
// Section order: Hero → Stack → Featured Work → Credibility → Writing → Contact CTA
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Reveal from '../components/Reveal.astro';
import StackStrip from '../components/StackStrip.astro';
import WorkCard from '../components/WorkCard.astro';
import StatBand from '../components/StatBand.astro';
import WritingTeaser from '../components/WritingTeaser.astro';
import ContactLinks from '../components/ContactLinks.astro';
---

<BaseLayout
  title="Guilherme de Mello — Senior iOS Engineer"
  description="Senior iOS Engineer based in Dublin. Crafting native Swift apps that feel inevitable — from architecture to App Store."
>
  <!-- Section 1: Hero — signature sticky-pin scrub -->
  <Hero />

  <!-- Section 2: Stack ---------------------------------------------------- -->
  <Reveal as="section" class="section-stack">
    <div class="container section">
      <p class="eyebrow section-eyebrow">The toolkit</p>
      <StackStrip />
    </div>
  </Reveal>

  <!-- Section 3: Featured Work --------------------------------------------- -->
  <Reveal as="section" id="work" class="section-work">
    <div class="container section">
      <header class="section-header">
        <p class="eyebrow section-eyebrow">Selected work</p>
        <h2 class="serif section-heading">Apps built to last.</h2>
      </header>

      <div class="work-grid">
        <!-- FoodLens -->
        <WorkCard
          title="FoodLens"
          blurb="AI food intelligence — scan a barcode and get an instant health score powered by Claude and on-device Foundation Models."
          meta="SwiftUI · Claude API · RevenueCat · App Store"
          href="#"
          cta="View on App Store →"
        />
        <!-- TODO: replace href with real App Store link -->

        <!-- Jornada -->
        <WorkCard
          title="Jornada"
          blurb="Personalised AI trip optimisation, fully native and offline-first. Plans adapt to your pace, not a server's."
          meta="SwiftUI · Claude API · MVVM-C"
          href="#"
        />
        <!-- TODO: replace href when project page is live -->

        <!-- Slope Verification @ EIDA -->
        <WorkCard
          title="Slope Verification @ EIDA"
          blurb="Position-aware smart annotations on construction drawings with sub-mm accuracy, built for field engineers."
          meta="PDFTron · GRDB · offline sync"
        />

        <!-- View all card -->
        <WorkCard
          title="View all work"
          blurb=""
          meta=""
          href="#"
          viewAll
        />
        <!-- TODO: replace href with /work page once Task 9 lands -->
      </div>
    </div>
  </Reveal>

  <!-- Section 4: Credibility ----------------------------------------------- -->
  <Reveal as="section" class="section-stats">
    <div class="container section">
      <p class="eyebrow section-eyebrow">By the numbers</p>
      <StatBand />
    </div>
  </Reveal>

  <!-- Section 5: Writing ---------------------------------------------------- -->
  <Reveal as="section" class="section-writing">
    <div class="container section">
      <header class="section-header">
        <p class="eyebrow section-eyebrow">From the blog</p>
        <h2 class="serif section-heading">Thinking out loud.</h2>
      </header>
      <WritingTeaser />
    </div>
  </Reveal>

  <!-- Section 6: Contact CTA ------------------------------------------------ -->
  <Reveal as="section" id="contact-cta" class="section-contact">
    <div class="container section">
      <p class="eyebrow section-eyebrow">Let's talk</p>
      <h2 class="serif section-heading">Building something native?</h2>
      <p class="section-lead muted">
        I am open to senior iOS engineering roles and collaborative projects
        where craft and architecture actually matter.
      </p>
      <ContactLinks />
    </div>
  </Reveal>

</BaseLayout>

<style>
  /* ==========================================================================
     Shared section scaffolding
     ========================================================================== */

  .section-eyebrow {
    margin-bottom: var(--sp-5);
  }

  .section-header {
    display: flex;
    flex-direction: column;
    margin-bottom: var(--sp-7);
  }

  .section-heading {
    font-family: 'Instrument Serif', Georgia, serif;
    font-weight: 400;
    font-size: var(--fs-h2);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--text);
  }

  .section-lead {
    font-size: var(--fs-body);
    line-height: 1.6;
    max-width: 52ch;
    color: var(--text-muted);
    margin-top: var(--sp-4);
    margin-bottom: var(--sp-7);
  }

  /* ==========================================================================
     Section 2 — Stack
     Subtle surface bg to visually separate from the hero.
     ========================================================================== */
  .section-stack {
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  /* ==========================================================================
     Section 3 — Work Grid
     ========================================================================== */
  .work-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-5);
  }

  @media (max-width: 760px) {
    .work-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ==========================================================================
     Section 4 — Stats
     Subtle surface bg for rhythm.
     ========================================================================== */
  .section-stats {
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  /* ==========================================================================
     Section 6 — Contact CTA
     ========================================================================== */
  .section-contact {
    background: var(--surface);
    border-top: 1px solid var(--border);
  }
</style>
